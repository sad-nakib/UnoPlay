rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms
    // Document ID: roomId (6-char uppercase string)
    // Fields:
    //   - roomId: string (required)
    //   - status: string (required, enum: lobby, playing, ended)
    //   - players: list (required) - Array of player objects {id, name, isReady, hand}
    //   - lastAction: string (optional)
    //   - winner: string (optional)
    //   - currentPlayerIndex: number (optional)
    //   - direction: number (optional)
    //   - currentEffect: string (optional)
    //   - wildColor: string (optional)
    //   - deck: list (optional)
    //   - discardPile: list (optional)
    //
    // ===============================================================

    match /rooms/{roomId} {
      // Allow anyone to read/write rooms for now as "no login required"
      // and rooms are identified by a 6-char random ID.
      // In a production app, we'd use anonymous auth and more granular checks.
      allow read, write: if true;
    }
  }
}
