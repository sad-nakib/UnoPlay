{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "A game room for UNO",
      "type": "object",
      "properties": {
        "roomId": { "type": "string" },
        "status": { "type": "string", "enum": ["lobby", "playing", "ended"] },
        "players": { "type": "array" },
        "lastAction": { "type": "string" },
        "winner": { "type": "string" }
      },
      "required": ["roomId", "status", "players"]
    }
  },
  "firestore": {
    "rooms/{roomId}": {
      "schema": "Room",
      "description": "Collection of active game rooms"
    }
  }
}
